# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/zewbie_primary
ANALYTICS_DATABASE_URL=postgresql://user:password@localhost:5432/zewbie_analytics
AUDIT_DATABASE_URL=postgresql://user:password@localhost:5432/zewbie_audit

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CLERK_SECRET_KEY=sk_test_xxxxx

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ─── AWS / S3 ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA_xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=zewbie-media

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
API_VERSION=1.0.0

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@zewbie.com
SMTP_PASS=xxxxx
EMAIL_FROM=noreply@zewbie.com

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
