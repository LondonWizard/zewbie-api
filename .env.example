# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase pooler connection string (session mode on port 5432)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:5432/postgres

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
# Fallback JWT (used when Clerk is not configured)
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# Clerk (set both for full auth integration)
CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ─── Stripe (deferred -- leave empty for mock fallbacks) ─────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-1
AWS_S3_BUCKET=zewbie-media-dev

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Comma-separated for multiple origins
FRONTEND_URL=http://localhost:5173
API_VERSION=1.0.0

# ─── Email (AWS SES -- configure later) ──────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@zewbie.com

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Cloudflare ──────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
