// Zewbie Universal API - Primary Database Schema
// Multi-database architecture: Primary (this file), Analytics, Audit (separate schemas)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  RETAILER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum RetailerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum StoreStatus {
  DRAFT
  PUBLISHED
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole  @default(USER)
  status        UserStatus @default(PENDING)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  retailerProfile RetailerProfile?
  stores          Store[]
  auditLogs       AuditLog[]

  @@index([email])
  @@index([role, status])
  @@map("users")
}

model RetailerProfile {
  id            String         @id @default(uuid())
  userId        String         @unique
  businessName  String
  businessEmail String
  description   String?
  logo          String?
  status        RetailerStatus @default(PENDING)
  tier          String         @default("standard")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([status])
  @@map("retailer_profiles")
}

model Store {
  id          String      @id @default(uuid())
  userId      String
  name        String
  slug        String      @unique
  domain      String?     @unique
  themeConfig Json        @default("{}")
  status      StoreStatus @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages         StorePage[]
  storeProducts StoreProduct[]
  orders        Order[]

  @@index([slug])
  @@index([userId])
  @@map("stores")
}

model StorePage {
  id          String   @id @default(uuid())
  storeId     String
  title       String
  slug        String
  content     Json     @default("{}")
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
  @@index([storeId])
  @@map("store_pages")
}

model Product {
  id          String        @id @default(uuid())
  retailerId  String
  name        String
  slug        String        @unique
  description String?
  sku         String        @unique
  basePrice   Decimal       @db.Decimal(10, 2)
  category    String?
  images      Json          @default("[]")
  status      ProductStatus @default(DRAFT)
  stock       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  retailer      RetailerProfile @relation(fields: [retailerId], references: [id], onDelete: Cascade)
  storeProducts StoreProduct[]

  @@index([retailerId])
  @@index([slug])
  @@index([status])
  @@map("products")
}

model StoreProduct {
  id                String   @id @default(uuid())
  storeId           String
  productId         String
  markup            Decimal  @default(0) @db.Decimal(10, 2)
  customDescription String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@unique([storeId, productId])
  @@index([storeId])
  @@map("store_products")
}

model Order {
  id              String      @id @default(uuid())
  storeId         String
  storeProductId  String
  quantity        Int
  totalPrice      Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  customerEmail   String
  customerName    String
  shippingAddress Json        @default("{}")
  trackingNumber  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  store        Store        @relation(fields: [storeId], references: [id])
  storeProduct StoreProduct @relation(fields: [storeProductId], references: [id])
  payments     Payment[]

  @@index([storeId])
  @@index([status])
  @@index([customerEmail])
  @@map("orders")
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  parentId    String?
  description String?
  image       String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

model Payment {
  id                    String        @id @default(uuid())
  orderId               String
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("usd")
  stripePaymentIntentId String?       @unique
  status                PaymentStatus @default(PENDING)
  createdAt             DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  metadata  Json     @default("{}")
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
